\begin_inset Formula 
\begin{align*}
\Gamma & =\gamma-\gamma{\color{red}\varphi}\frac{\lambda-\tau}{1-\lambda}\frac{(1-\Phi)(\varphi+(1-\alpha)\gamma)-\Phi}{{\color{red}\varphi+(1-\Phi)(1-\alpha)\gamma}}\\
 & +\kappa^{S}\left\{ \Phi-\frac{\lambda-\tau}{1-\lambda}\left[(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi\right]\right\} 
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\kappa^{S}$
\end_inset

の中は共通
\end_layout

\begin_layout Itemize
\begin_inset Formula $0<\frac{\varphi}{\varphi+(1-\Phi)(1-\alpha)\gamma}\leq1$
\end_inset

より、
\begin_inset Formula $C^{S}\geq C$
\end_inset

なら、
\begin_inset Formula $\Gamma\geq(C^{S}/C)\Upsilon\geq\Upsilon$
\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
NK IS Equation:
\begin_inset Formula 
\begin{align*}
r_{t} & =mu^{S}_{t}-\mathbb{E}_{t}\left[mu^{S}_{t+1}\right]=-\Upsilon\left(y_{t}-\mathbb{E}_{t}\left[y_{t+1}\right]\right)
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $C^{S}>C$
\end_inset

のもと、NK-IS曲線の傾きはフラットに
\end_layout

\begin_layout Itemize
\begin_inset Formula $\lambda=0$
\end_inset

 (RANK):
\begin_inset Formula 
\[
\Upsilon=\frac{C}{C^{S}}\left(\gamma+\kappa^{S}\Phi\right)
\]

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\kappa^{S}=0$
\end_inset

 (CRRA preferences):
\begin_inset Formula 
\begin{align*}
\Upsilon & =\frac{C}{C^{S}}\gamma\left(1-\frac{\lambda-\tau}{1-\lambda}\{(1-\Phi)\{\varphi+(1-\alpha)\gamma\}-\Phi\}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma=0$
\end_inset

 (GHH preferences):
\begin_inset Formula 
\begin{align*}
\Upsilon & =\frac{C}{C^{S}}\kappa^{S}\left(\Phi-\frac{\lambda-\tau}{1-\lambda}\varphi\right)\\
 & =\xi\frac{(\varphi+1)C}{(\varphi+1)C^{S}-(1-\alpha)(1-\Phi)C}\left(\Phi-\frac{\lambda-\tau}{1-\lambda}\varphi\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=\alpha=0$
\end_inset

 (efficient & linear economy):
\begin_inset Formula 
\begin{align*}
\Upsilon & =\frac{C}{C^{S}}\left\{ \gamma-\frac{\lambda}{1-\lambda}(\varphi+\gamma)(\gamma+\kappa^{S})\right\} \\
 & =\frac{C}{C^{S}}\left\{ \gamma-\frac{(\lambda-\tau)}{1-\lambda}\left\{ \gamma(\varphi+\gamma)+\xi(\varphi+1)\right\} \right\} 
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=0$
\end_inset

 (efficient economy):
\begin_inset Formula 
\begin{align*}
\Upsilon & =\frac{C}{C^{S}}\left\{ \gamma-\frac{\lambda}{1-\lambda}(\gamma(1-\alpha)+\varphi)(\gamma+\kappa^{S})\right\} 
\end{align*}

\end_inset


\end_layout

\end_deeper
\end_deeper
