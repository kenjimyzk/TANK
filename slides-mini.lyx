\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
GE-EIS is positive iff 
\begin_inset Formula $\lambda<\lambda^{+}$
\end_inset

 where
\begin_inset Formula 
\begin{align*}
\lambda^{+}= & \frac{\gamma+\kappa^{S}\Phi+(\gamma+\kappa^{S})\tau\left[(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi\right]}{\gamma+\kappa^{S}\Phi+(\gamma+\kappa^{S})\left[(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi\right]}
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\kappa^{S}=0$
\end_inset

 (CRRA preferences):
\begin_inset Formula 
\begin{align*}
\lambda^{+} & =\frac{1+\tau\left[(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi\right]}{1+(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi}\\
 & =\tau+\frac{1-\tau}{1+(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma=0$
\end_inset

 (GHH preferences):
\begin_inset Formula 
\begin{align*}
\lambda^{+}= & \frac{\Phi+\tau\left[(1-\Phi)\varphi-\Phi\right]}{\Phi+\left[(1-\Phi)\varphi-\Phi\right]}\\
= & \tau+\frac{\Phi(1-\tau)}{\varphi(1-\Phi)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=\alpha=0$
\end_inset

 (efficient & linear economy):
\begin_inset Formula 
\begin{align*}
\lambda^{+} & =\frac{\gamma+(\gamma+\kappa^{S})\tau(\gamma+\varphi)}{\gamma+(\gamma+\kappa^{S})(\gamma+\varphi)}\\
 & =\tau+\frac{(1-\tau)\gamma}{\gamma(\varphi+\gamma+1)+\xi(\varphi+1)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=0$
\end_inset

 (efficient economy):
\begin_inset Formula 
\begin{align*}
\lambda^{+} & =\frac{\gamma+(\gamma+\kappa^{S})\tau\left[(\gamma(1-\alpha)+\varphi)\right]}{\gamma+(\gamma+\kappa^{S})\left[(\gamma(1-\alpha)+\varphi)\right]}\\
= & \tau+\frac{(1-\tau)\gamma}{\gamma+(\gamma+\kappa^{S})\left[(\gamma(1-\alpha)+\varphi)\right]}
\end{align*}

\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
GE-EIS is decreasing in 
