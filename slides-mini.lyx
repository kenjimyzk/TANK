\pi_{t} & =(1-\Phi)(\psi/\eta)\{\gamma+(\varphi+\alpha)/(1-\alpha)\}y_{t}+\beta E_{t}\pi_{t+1}\\
 & =\Psi y_{t}+\beta E_{t}\pi_{t+1}\\
mu^{S}_{t} & =-(\gamma+\kappa^{S})c^{S}_{t}+\kappa^{S}(1-\alpha)(1-\Phi)n^{S}_{t}\\
r_{t} & =mu^{S}_{t}-\mathbb{E}_{t}\left[mu^{S}_{t+1}\right]\\
 & =r^{N}_{t}-E_{t}\pi_{t+1}\\
r^{N}_{t} & =\phi\pi_{t}-m_{t}
\end{align*}

\end_inset


\end_layout

