\begin{align*}
c^{H}_{t} & =(1+\tilde{\varphi})y_{t}\\
c^{S}_{t} & =\left(1-\frac{\lambda\tilde{\varphi}}{1-\lambda}\right)y_{t}\\
\tilde{\varphi} & =\varphi(1-\tau/\lambda)\frac{(1-\Phi)(\varphi+(1-\alpha)\gamma)-\Phi}{\varphi+(1-\Phi)(1-\alpha)\gamma}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\tilde{\varphi}>0$
\end_inset

の時、タイプHの消費が弾力的で、タイプSより非弾力的
\end_layout

\begin_layout Itemize
\begin_inset Formula $\tilde{\varphi}>0$
\end_inset

 iff 
\begin_inset Formula $\varphi(\lambda-\tau)\{(1-\Phi)\{\varphi+(1-\alpha)\gamma\}-\Phi\}>0$
\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\lambda=\tau$
\end_inset

の時、
\begin_inset Formula $\tilde{\varphi}=0$
\end_inset

.
\end_layout

\begin_layout Itemize
\begin_inset Formula $(1-\Phi)\{\varphi+(1-\alpha)\gamma\}-\Phi>0$
\end_inset

 iff 
\begin_inset Formula $\Phi<\{\varphi+(1-\alpha)\gamma\}/\{1+\varphi+(1-\alpha)\gamma\}$
\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
Labor inputs:
\end_layout

\begin_deeper
\begin_layout Standard
\begin_inset Formula 
\begin{align*}
n^{H}_{t} & =\left(\frac{1}{1-\alpha}-\tilde{\gamma}\right)y_{t}\\
n^{S}_{t} & =\left(\frac{1}{1-\alpha}+\frac{\lambda\tilde{\gamma}}{1-\lambda}\right)y_{t}\\
\tilde{\gamma} & =\gamma(1-\tau/\lambda)\frac{(1-\Phi)(\varphi+(1-\alpha)\gamma)-\Phi}{\varphi+(1-\Phi)(1-\alpha)\gamma}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\tilde{\gamma}>0$
\end_inset

の時、タイプSの労働がタイプHより弾力的に
\end_layout

\begin_layout Itemize
\begin_inset Formula $\tilde{\gamma}>0$
\end_inset

 iff 
\begin_inset Formula $\gamma(\lambda-\tau)\{(1-\Phi)\{\varphi+(1-\alpha)\gamma\}-\Phi\}>0$
\end_inset


\end_layout

