\begin_deeper
\begin_layout Itemize
IS曲線の傾きはGE-EISの逆数である
\end_layout

\begin_layout Itemize
EIS (Elasticity of Intertemporal Substitution):
 異時点間の代替の弾力性に変化率対する消費の増加率
\begin_inset Formula 
\[
-\frac{\partial\ln(C^{S}_{t+1}/C^{S}_{t})}{\partial\ln(MU^{S}_{t+1}/MU^{S}_{t})}=-\frac{\partial(c^{S}_{t+1}-c^{S}_{t})}{\partial(mu^{S}_{t+1}-mu^{S}_{t})}=\frac{1}{\gamma+\kappa^{S}}
\]

\end_inset


\end_layout

\begin_layout Itemize
GE-EIS (General Equilibrium EIS):
 均衡において、消費は生産量と等しく、異時点間の代替の弾力性は実質利子率の逆数と等しくなる
\begin_inset Formula 
\begin{align*}
-\frac{d\ln(\mathbb{E}_{t}Y_{t+1}/Y_{t})}{d\ln(\mathbb{E}_{t}INFL_{t+1}/INT_{t})} & =\frac{d(\mathbb{E}_{t}y_{t+1}-y_{t})}{dr_{t}}\\
 & :=\Gamma^{-1}.
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
GE-EIS is positive iff 
\begin_inset Formula $\lambda<\lambda^{+}$
\end_inset

 where
\begin_inset Formula 
\begin{align*}
\lambda^{+}= & \tau+\frac{(1-\tau)(\gamma+\kappa^{S}\Phi)}{(1-\Phi)(\varphi+\gamma(1-\alpha))\left\{ \frac{\gamma(\varphi+1)}{\varphi+(1-\Phi)(1-\alpha)\gamma}+\kappa^{S}\right\} }
\end{align*}

\end_inset

decreasing in 
\begin_inset Formula $\kappa^{S}$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\kappa^{S}=0$
\end_inset

 (CRRA preferences):
\begin_inset Formula 
\begin{align*}
\lambda^{+} & =\tau+\frac{(1-\tau)\{\varphi+(1-\Phi)(1-\alpha)\gamma\}}{(1-\Phi)(\varphi+1)(\gamma(1-\alpha)+\varphi)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma=0$
\end_inset

 (GHH preferences):
\begin_inset Formula 
\begin{align*}
\lambda^{+}= & \tau+\frac{\Phi(1-\tau)}{\varphi(1-\Phi)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=\alpha=0$
\end_inset

 (efficient & linear economy):
\begin_inset Formula 
\begin{align*}
\lambda^{+} & =\tau+\frac{(1-\tau)\gamma}{\gamma(\varphi+1)+\xi(\varphi+1)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=0$
\end_inset

 (efficient economy):
\begin_inset Formula 
\begin{align*}
\lambda^{+}= & \tau+\frac{(1-\tau)\gamma}{\gamma(\varphi+1)+\kappa^{S}\{\varphi+(1-\alpha)\gamma\}}
\end{align*}

\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
GE-EIS is decreasing in 
\begin_inset Formula $\kappa^{S}$
\end_inset

 in the case with RANK (
\begin_inset Formula $\lambda=0$
\end_inset

).
\end_layout

\begin_layout Itemize
GE-EIS is increasing in 
\begin_inset Formula $\kappa^{S}$
\end_inset

 iff 
\begin_inset Formula $\lambda>\lambda^{\xi}$
\end_inset


\begin_inset Formula 
\begin{align*}
\lambda^{\xi} & =\tau+\frac{\Phi(1-\tau)}{(1-\Phi)\{\varphi+\gamma(1-\alpha)\gamma\}}
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\gamma=0$
\end_inset

 (GHH preferences):
\begin_inset Formula 
\begin{align*}
\lambda^{\xi}= & \tau+\frac{\Phi(1-\tau)}{\varphi(1-\Phi)}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\Phi=0$
\end_inset

 (efficient economy):
\begin_inset Formula 
\begin{align*}
\lambda^{\xi} & =\tau
\end{align*}

\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
GE-EIS is increasing in 
\begin_inset Formula $\lambda$
\end_inset

 iff 
\begin_inset Formula 
\[
(\lambda-\tau)\left\{ (1-\Phi)(\varphi+(1-\alpha)\gamma)-\Phi\right\} >0
\]

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
