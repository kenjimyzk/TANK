\begin_deeper
\begin_layout Itemize
Bilbiie (2020) は以下の効用関数を提案 (
\begin_inset Formula $\varphi>0$
\end_inset

,
 
\begin_inset Formula $\gamma\geq0$
\end_inset

)：

\begin_inset Formula 
\[
U^{j}_{t}=U(C^{j}_{t},N^{j}_{t})=\frac{1}{1-\gamma-\xi}\left([C^{j}_{t}]^{1-\gamma}-\frac{1-\gamma}{1+\varphi}[N_{t}]^{1+\varphi}\right)^{1-\xi/(1-\gamma)}
\]

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\xi=0$
\end_inset

のときCRRA型:
\begin_inset Formula 
\[
U^{j}_{t}=[C^{j}_{t}]^{1-\gamma}-\frac{1-\gamma}{1+\varphi}[N^{j}_{t}]^{1+\varphi}
\]

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma=0$
\end_inset

のときGHH型:
\begin_inset Formula 
\[
U^{j}_{t}=\frac{1}{1-\xi}\left(C^{j}_{t}-\frac{1}{1+\varphi}[N^{j}_{t}]^{1+\varphi}\right)^{1-\xi}
\]

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma\to1$
\end_inset

のときKPR型:
 
\begin_inset Formula 
\[
U^{j}_{t}=-\frac{1}{\xi}\left[C^{j}_{t}\exp\left\{ -\frac{[N^{j}_{t}]^{1+\varphi}}{1+\varphi}\right\} \right]^{-\xi}
\]

\end_inset


\end_layout

\end_deeper
\begin_layout Itemize
以下の関係が成立：

\begin_inset Formula 
\begin{align*}
\gamma & =-\frac{U^{j}_{CC}C^{j}}{U_{C}}+\frac{U^{j}_{CN}C^{j}}{U_{N}}\\
\varphi & =\frac{U^{j}_{NN}N^{j}}{U_{N}}-\frac{U^{j}_{CN}N^{j}}{U_{C}}\\
\xi & =-\frac{U_{CN}C}{U_{N}}\left(1+\frac{1-\gamma}{1+\varphi}\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}\right)
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $U^{j}_{C}:=\partial U(C^{j},N^{j})/\partial C^{j}$
\end_inset

,
 
\begin_inset Formula $U^{j}_{N}:=\partial U(C^{j},N^{j})/\partial N^{j}$
\end_inset

,
 
\begin_inset Formula $U^{j}_{CC}:=\partial^{2}U(C^{j},N^{j})/\partial(C^{j})^{2}$
\end_inset

,
 
\begin_inset Formula $U^{j}_{NN}:=\partial^{2}U(C^{j},N^{j})/\partial(N^{j})^{2}$
\end_inset

,
 
\begin_inset Formula $U^{j}_{CN}:=\partial^{2}U(C^{j},N^{j})/\partial(C^{j})\partial(N^{j})$
\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma$
\end_inset

:
 消費が1％増加した際に、限界代替率
\begin_inset Formula $MRS^{j}_{t}=-U^{j}_{C,t}/U^{j}_{N,t}$
\end_inset

がどれだけ変化するかを示すパラメータ
\end_layout

\begin_layout Itemize
\begin_inset Formula $\varphi$
\end_inset

:
 労働が1％増加した際に、限界代替率
\begin_inset Formula $MRS^{j}_{t}=-U^{j}_{C,t}/U^{j}_{N,t}$
\end_inset

がどれだけ変化するかを示すパラメータ
\end_layout

\end_deeper
\begin_layout Itemize
補完性 (complementarity)：

\begin_inset Formula 
\begin{align*}
\kappa^{j} & :=-\frac{U^{j}_{CN}C^{j}}{U^{j}_{N}}\\
 & =\xi\left(1+\frac{1-\gamma}{1+\varphi}\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}\right)^{-1}
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\kappa^{j}$
\end_inset

:
 消費が1％増加した際に、労働の限界不効用（
\begin_inset Formula $U^{j}_{N}$
\end_inset

）がどれだけ変化するかを示す（消費と労働が補完的な財である度合い）
\end_layout

\begin_layout Itemize
\begin_inset Formula $\kappa>0$
\end_inset

のとき補完的、
\begin_inset Formula $\kappa<0$
\end_inset

のとき代替的という
\end_layout

\begin_layout Itemize
\begin_inset Formula $\xi$
\end_inset

と
\begin_inset Formula $\kappa$
\end_inset

は比例関係で、
\begin_inset Formula $\xi$
\end_inset

を非分離性のパラメータとよぶ
\end_layout

\end_deeper
\begin_layout Itemize
賃金が限界代替率に等しいとき（
\begin_inset Formula $W_{t}=MRS^{j}_{t}$
\end_inset

）の対数線形近似：

\begin_inset Formula 
\[
w_{t}=\gamma c^{j}_{t}+\varphi n^{j}_{t}
\]

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $\varphi$
\end_inset

の逆数は（消費一定のもとの）賃金弾力性である。
ただしフリッシュ弾力性（限界効用一定のもとの賃金弾力性）でない
\end_layout

\begin_layout Itemize
\begin_inset Formula $\gamma$
\end_inset

は所得効果と呼ぶ。
必ずしも異時点間の代替の弾力性の逆数や相対的危険回避度にならない
\end_layout

\begin_layout Itemize
労働の所得弾力性は
\begin_inset Formula $-\gamma/\varphi$
\end_inset

で、ミクロの実証を再現しようとすると
\begin_inset Formula $\gamma$
\end_inset

を限りなくゼロにするか、
\begin_inset Formula $\varphi$
\end_inset

巨大にする必要がある。

\end_layout

\end_deeper
\begin_layout Itemize
消費についての限界効用 (
\begin_inset Formula $MU^{j}_{t}:=U^{j}_{C}$
\end_inset

) の対数線形近似：

\begin_inset Formula 
\begin{align*}
mu^{j}_{t} & =\frac{U^{j}_{CC}C^{j}}{U_{C}}c_{t}+\frac{U^{j}_{CN}N^{j}}{U^{j}_{C}}n^{j}_{t}\\
 & =-(\gamma+\kappa^{j})c_{t}-\kappa^{j}\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}n_{t}
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
消費の限界効用が、消費が増えると減少する。
消費と労働が補完関係があるならが増えるとさらに加速する
\end_layout

\begin_layout Itemize
消費の限界効用は、消費と労働が補完関係があるなら労働供給が増えるほど高まる。
（忙しいほど消費の価値が上がる）
\end_layout

\end_deeper
\begin_layout Itemize
凹性（concavity）の条件
\begin_inset Formula 
\begin{align*}
\kappa & \geq-\gamma\varphi\left(\varphi-\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}\gamma\right)^{-1}\\
\Leftrightarrow\xi & \geq-\gamma\varphi\left(\varphi-\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}\gamma\right)^{-1}\left(1+\frac{1-\gamma}{1+\varphi}\frac{N^{j}}{C^{j}}\frac{U^{j}_{N}}{U^{j}_{C}}\right)
\end{align*}

\end_inset


\end_layout

\end_deeper
