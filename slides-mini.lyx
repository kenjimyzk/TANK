GE-EIS:
 
\begin_inset Formula 
\begin{align*}
1/\Upsilon & =\frac{C^{S}/C,}{\gamma+\kappa^{S}\Phi-(\gamma+\kappa^{S})\frac{(\lambda-\tau)\left[(1-\Phi)(\gamma(1-\alpha)+\varphi)-\Phi\right]}{1-\lambda}}
\end{align*}

\end_inset


\end_layout

\begin_deeper
\begin_layout Itemize
\begin_inset Formula $C^{S}/C$
\end_inset

,
 increasing in 
\begin_inset Formula $\lambda$
\end_inset


\end_layout

\begin_layout Itemize
