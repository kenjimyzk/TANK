\end_layout

\begin_layout Itemize
Type S Household:
\begin_inset Formula 
\begin{align*}
mu^{S}_{t} & =-(\gamma+\kappa^{S})c^{S}_{t}+{\color{red}\kappa^{S}}(1-\Phi)(1-\alpha)\frac{1-{\color{red}\lambda^{n}}}{1-{\color{red}\lambda^{c}}}n^{S}_{t}\\
r_{t} & :=r^{N}_{t}-E_{t}\pi_{t+1}\\
 & =mu^{S}_{t}-\mathbb{E}_{t}\left[mu^{S}_{t+1}\right]\\
w_{t} & =\gamma c^{S}_{t}+\varphi n^{S}_{t}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
Type H Household:
\begin_inset Formula 
\begin{align*}
{\color{red}\lambda^{c}}c^{H}_{t} & =(1-\alpha)(1-\Phi){\color{red}\lambda^{n}}(w_{t}+n^{H}_{t})+\tau^{D}d_{t}\\
w_{t} & =\gamma c^{H}_{t}+\varphi n^{H}_{t}
